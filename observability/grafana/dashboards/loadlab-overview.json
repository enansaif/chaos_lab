{
  "annotations": {"list": []},
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "fieldConfig": {"defaults": {"unit": "reqps"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "id": 1,
      "title": "HTTP Request Rate",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(http_server_duration_milliseconds_count[1m]))",
          "legendFormat": "requests/s",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "fieldConfig": {"defaults": {"unit": "ms"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "id": 2,
      "title": "HTTP p95 Latency",
      "type": "timeseries",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_duration_milliseconds_bucket[5m])) by (le))",
          "legendFormat": "p95",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {"type": "loki", "uid": "Loki"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "id": 3,
      "title": "Slow Requests (logs)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(count_over_time({service=\"api\"} |= \"slow_request\" [1m]))",
          "legendFormat": "slow/min",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {"type": "loki", "uid": "Loki"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "id": 4,
      "title": "Celery Task Completions",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(count_over_time({service=\"worker\"} |= \"succeeded\" [1m]))",
          "legendFormat": "tasks/min",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {"type": "loki", "uid": "Loki"},
      "gridPos": {"h": 10, "w": 24, "x": 0, "y": 16},
      "id": 5,
      "title": "Recent API Logs",
      "type": "logs",
      "targets": [
        {
          "expr": "{service=~\"api|worker|nginx\"}",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "10s",
