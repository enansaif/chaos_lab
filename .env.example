# =============================================================================
# Django Distributed Systems Load Lab — Environment Configuration
# Copy to .env and adjust toggles for experiments.
# =============================================================================

# --- Django ---
DEBUG=true
SECRET_KEY=change-me-in-production-use-a-long-random-string
ALLOWED_HOSTS=localhost,127.0.0.1,api,nginx
DJANGO_SETTINGS_MODULE=config.settings

# --- PostgreSQL ---
POSTGRES_DB=loadlab
POSTGRES_USER=loadlab
POSTGRES_PASSWORD=loadlab
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_CONN_MAX_AGE=60

# --- Redis (logical DB separation) ---
# DB 0: Celery broker (when CELERY_BROKER_BACKEND=redis)
# DB 1: Django cache
# DB 2: Celery result backend
REDIS_URL=redis://redis:6379/0
REDIS_CACHE_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# --- RabbitMQ (alternative Celery broker) ---
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672//
RABBITMQ_DEFAULT_USER=guest
RABBITMQ_DEFAULT_PASS=guest

# --- Celery broker switch: redis | rabbitmq ---
CELERY_BROKER_BACKEND=redis
CELERY_CONCURRENCY=4
CELERY_TASK_SLEEP_SECONDS=0.5

# --- Cache toggle ---
CACHE_ENABLED=true
CACHE_TTL_SECONDS=60

# --- Uvicorn / API ---
UVICORN_WORKERS=4
SERVICE_ROLE=api

# --- Nginx ---
NGINX_RATE_LIMIT=0

# --- Logging ---
LOG_LEVEL=INFO
SLOW_REQUEST_MS=500

# --- Seed data ---
SEED_PRODUCT_COUNT=10000

# --- Load test defaults (used by Makefile) ---
LOCUST_USERS=50
LOCUST_SPAWN_RATE=10
LOCUST_RUN_TIME=5m

# --- OpenTelemetry ---
OTEL_ENABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_SERVICE_NAME=loadlab-api
OTEL_TRACES_SAMPLER_ARG=1.0

# --- Grafana ---
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
