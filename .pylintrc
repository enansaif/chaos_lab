[MASTER]
init-hook=
  import sys;
  from pathlib import Path;
  root = Path.cwd();
  candidates = [root, *root.parents];
  [sys.path.insert(0, str(p / "src")) for p in candidates if (p / "src" / "manage.py").exists()];
  [sys.path.insert(0, str(p)) for p in candidates if (p / "manage.py").exists()]

[MESSAGES CONTROL]
disable=
    missing-module-docstring,
    missing-class-docstring,
    import-outside-toplevel
